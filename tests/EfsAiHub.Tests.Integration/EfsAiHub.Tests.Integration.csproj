    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);OPENAI001;MEAI001;MAAIW001</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="8.0.25" />
    <PackageReference Include="xunit" Version="2.9.3" />
