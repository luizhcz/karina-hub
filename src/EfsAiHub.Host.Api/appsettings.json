{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Hosting": "Information",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=efs_ai_hub;Username=efs_ai_hub;Password=change_me_in_production;Search Path=aihub",
    "PostgresReporting": ""
  },
  "AzureAI": {
    "Endpoint": "https://efs-ai-hub-resource.services.ai.azure.com",
    "DefaultDeploymentName": "gpt-4o",
    "ApiKey": ""
  },
  "OpenAI": {
    "ApiKey": "",
    "DefaultModel": "gpt-5.4-nano"
  },
  "WorkflowEngine": {
    "MaxConcurrentExecutions": 10,
    "ChatMaxConcurrentExecutions": 200,
    "QueueCapacity": 500,
    "AdminQueueCapacity": 300,
    "DefaultTimeoutSeconds": 300,
    "CheckpointMode": "InMemory",
    "EnableScheduledWorkflows": true,
    "HitlRecoveryConcurrency": 4,
    "HitlRecoveryBatchSize": 100,
    "AuditRetentionDays": 30,
    "ToolInvocationRetentionDays": 14,
    "CheckpointRetentionDays": 14
  },
  "OpenTelemetry": {
    "ServiceName": "efs-ai-hub",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableSensitiveData": false
  },
  "Npgsql": {
    "SseMaxPoolSize": 50,
    "ReportingMaxPoolSize": 20,
    "GeneralMinPoolSize": 10,
    "GeneralMaxPoolSize": 500
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "efs-ai-hub:",
    "DefinitionCacheTtlSeconds": 300
  },
  "AtivoAnalysis": {
    "IntervalHours": 24,
    "RotationDays": 20,
    "DelayBetweenTriggersMs": 2000
  },
  "Admin": {
    "AccountIds": ["011982329"]
  },
  "ChatRouting": {
    "DefaultWorkflows": {
      "cliente": "atendimento-cliente",
      "assessor": "atendimento-assessor"
    }
  },
  "DocumentIntelligence": {
    "Endpoint": "https://efs-ai-hub-resource.cognitiveservices.azure.com",
    "UseManagedIdentity": true,
    "DefaultModel": "prebuilt-layout",
    "MaxPages": 100,
    "PollingTimeoutSeconds": 180,
    "GateWaitTimeoutSeconds": 600,
    "CacheTtlDays": 1
  }
}
