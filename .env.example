# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Em dev, a connection string é montada no docker-compose.yml a partir destas
# vars. Em prod, mova pra Secrets:Bootstrap apontando ref AWS Secrets Manager
# (ex: ConnectionStrings:Postgres → secret://aws/efs-ai-hub/postgres).
POSTGRES_DB=efs_ai_hub
POSTGRES_USER=efs_ai_hub
POSTGRES_PASSWORD=change_me

# ── LLM Provider — endpoints / deployments (NÃO são secrets) ─────────────────
OPENAI_DEFAULT_MODEL=gpt-4o
AZURE_AI_ENDPOINT=https://{SEU_HUB}.services.ai.azure.com
AZURE_AI_DEFAULT_DEPLOYMENT=gpt-4o
DOCUMENT_INTELLIGENCE_ENDPOINT=https://{SEU_HUB}.cognitiveservices.azure.com

# ── AWS Secrets Manager ──────────────────────────────────────────────────────
# Credentials via default chain (IAM role em prod, perfil nomeado em dev).
# Configure `aws configure --profile efs-dev` localmente. Backend lê secrets
# referenciados em Secrets:Bootstrap (appsettings.*.json) na startup.
AWS_REGION=us-east-1
AWS_PROFILE=efs-dev

# ── Redis (opcional — padrão: localhost:6379) ─────────────────────────────────
# REDIS_CONNECTION_STRING=localhost:6379

# ── OpenTelemetry (opcional) ──────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Secrets que SAÍRAM deste arquivo (PR 3 da migração AWS Secrets Manager) ──
# As variáveis abaixo NÃO devem mais ficar em .env. Configure no AWS Secrets
# Manager e referencie via Secrets:Bootstrap em appsettings.{Env}.json:
#
#   OPENAI_API_KEY                → Secrets:Bootstrap → OpenAI:ApiKey
#   AZURE_AI_API_KEY              → Secrets:Bootstrap → AzureAI:ApiKey
#   DOCUMENT_INTELLIGENCE_API_KEY → Secrets:Bootstrap → DocumentIntelligence:ApiKey
#   AZURE_TENANT_ID               → Secrets:Bootstrap → Azure:ServicePrincipal:TenantId
#   AZURE_CLIENT_ID               → Secrets:Bootstrap → Azure:ServicePrincipal:ClientId
#   AZURE_CLIENT_SECRET           → Secrets:Bootstrap → Azure:ServicePrincipal:ClientSecret
#
# Operadores que precisarem rodar dev sem AWS: setar as chaves diretamente em
# `dotnet user-secrets` ou em `appsettings.Development.json` (gitignored).
