# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=efs_ai_hub
POSTGRES_USER=efs_ai_hub
POSTGRES_PASSWORD=change_me
# Search Path é definido automaticamente na connection string — schema utilizado: aihub

# ── LLM Provider — configure OpenAI E/OU Azure AI ──────────────────────────

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_DEFAULT_MODEL=gpt-4o

# Azure AI Foundry
AZURE_AI_ENDPOINT=https://{SEU_HUB}.services.ai.azure.com
AZURE_AI_API_KEY=your-azure-ai-key
AZURE_AI_DEFAULT_DEPLOYMENT=gpt-4o

# ── Redis (opcional — padrão: localhost:6379) ─────────────────────────────────
# REDIS_CONNECTION_STRING=localhost:6379

# ── OpenTelemetry (opcional) ──────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
